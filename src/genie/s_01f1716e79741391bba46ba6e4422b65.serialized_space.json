      {
        "id": "01f17648e3d419fea5e9a18f2864292d",
        "question": [
          "Quantos arranjos de pagamento existem por bandeira?"
        ],
        "answer": [
          {
            "format": "SQL",
            "content": [
              "SELECT bandeira, COUNT(*) AS arranjos\n",
              "FROM dev_recebiveis.diamond.dim_arranjo\n",
              "GROUP BY bandeira\n",
              "ORDER BY arranjos DESC"
            ]
          }
        ]
      },
      {
        "id": "01f17648db9b19fda60e08f77a43569b",
        "question": [
          "Quantos cedentes existem por UF?"
        ],
        "answer": [
          {
            "format": "SQL",
            "content": [
              "SELECT uf, COUNT(*) AS cedentes\n",
              "FROM dev_recebiveis.diamond.dim_cedente\n",
              "GROUP BY uf\n",
              "ORDER BY cedentes DESC"
            ]
